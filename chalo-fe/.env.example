# Public backend API base URL used by browser-side API calls and SSE connections.
# Example: http://localhost:8080/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Enables MSW browser mocks in development when set exactly to true.
# Example: false
NEXT_PUBLIC_ENABLE_MSW=false

# Server-side backend API base URL used by Next.js server components/services.
# Example: http://localhost:8080/api
INTERNAL_API_BASE_URL=http://localhost:8080/api

# Next.js runtime mode. Usually set automatically by Next.js commands.
# Example: development
NODE_ENV=development
