# =========================================================
# Chalo Coffee — biến môi trường PRODUCTION
# Trên VPS:  cp deploy/.env.example .env   rồi sửa các giá trị bên dưới.
# File .env (thật) KHÔNG commit lên git.
# =========================================================

# ---- Tên miền & SSL ----
DOMAIN=chalocoffee.com
# Email để Let's Encrypt gửi cảnh báo hết hạn chứng chỉ.
ACME_EMAIL=ban@vidu.com

# ---- Database (Postgres chạy trong docker) ----
DB_DATABASE=chalo_coffee
DB_USERNAME=chalo_user
# ĐỔI thành mật khẩu mạnh. Gợi ý tạo: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_mat_khau_db_manh

# ---- JWT (BẮT BUỘC đổi — backend sẽ chặn khởi động nếu để giá trị mặc định) ----
# Tạo mỗi cái bằng:  openssl rand -hex 32
# Hai giá trị PHẢI khác nhau.
JWT_SECRET=CHANGE_ME_chay_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_chay_openssl_rand_hex_32_KHAC
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Seed dữ liệu ban đầu ----
# Đặt true ở lần deploy ĐẦU để tạo: tài khoản admin/admin + staff/staff, menu mẫu, 30 bàn.
# Production KHÔNG tạo đơn hàng giả, KHÔNG xoá dữ liệu, và idempotent (chạy lại không nhân đôi).
# Sau lần đầu nên đặt lại false cho gọn (xem README mục 6).
SEED_ON_STARTUP=false
