# Runtime environment for the NestJS backend.
# Example: development
NODE_ENV=development

# HTTP port used by the backend server.
# Example: 8080
PORT=8080

# Public URL where this backend is reachable; used in logs and production config.
# Example: http://localhost:8080
APP_URL=http://localhost:8080

# Allowed browser origins for CORS. Use a comma-separated list for multiple origins.
# Example: http://localhost:3000,http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Reserved: public frontend URL. Declared/validated in env schema but not yet read by any backend code.
# Example: http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000

# PostgreSQL host for TypeORM and migration commands.
# Example: localhost
DB_HOST=localhost

# PostgreSQL port for TypeORM and migration commands.
# Example: 5432
DB_PORT=5432

# PostgreSQL username for the application.
# Example: chalo_user
DB_USERNAME=chalo_user

# PostgreSQL password for the application. Do not commit a real password.
# Example: your-db-password-here
DB_PASSWORD=your-db-password-here

# PostgreSQL database name used by the application.
# Example: chalo_coffee
DB_DATABASE=chalo_coffee

# Controls TypeORM schema synchronization. Keep false outside disposable local development.
# Example: false
DB_SYNCHRONIZE=false

# Secret used to sign JWT access tokens. Use a long random value in real environments.
# Example: your-access-token-secret-here
JWT_SECRET=your-access-token-secret-here

# Secret used to sign JWT refresh tokens. Must be different from JWT_SECRET.
# Example: your-refresh-token-secret-here
JWT_REFRESH_SECRET=your-refresh-token-secret-here

# Access-token lifetime passed to jsonwebtoken.
# Example: 15m
JWT_ACCESS_EXPIRES=15m

# Refresh-token lifetime passed to jsonwebtoken.
# Example: 7d
JWT_REFRESH_EXPIRES=7d

# Enables destructive startup seeding when set exactly to true. Leave false for normal use.
# Example: false
SEED_ON_STARTUP=false

# Reserved: intended seed admin password. NOT yet honored — seed.service.ts currently hardcodes "admin".
# Example: your-seed-admin-password-here
SEED_ADMIN_PASSWORD=your-seed-admin-password-here

# Reserved: intended seed staff password. NOT yet honored — seed.service.ts currently hardcodes "staff".
# Example: your-seed-staff-password-here
SEED_STAFF_PASSWORD=your-seed-staff-password-here
